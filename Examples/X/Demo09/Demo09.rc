; ==================================================================================================
; Title:      Demo09.rc
; Author:     G. Friedrich
; Purpose:    Resource script for ObjAsm demonstration application Demo09.
; Version:    See Demo09.asm
;
; Description:
;   This file defines the resource entries used by the Demo09 ObjAsm application.
;   It is processed by the Resource Compiler (RC.EXE) to generate a .res file that
;   becomes part of the final executable. The script provides the metadata, version
;   information, and application icon required for proper identification within
;   the Windows environment.
;
; ==================================================================================================


#include "Resource.h"                                   ; Windows resource definitions
#include "Demo09_Shared.rc"                             ; Application shared definitions
#include "VER\Version.rc"                               ; Application version definition
#include "MFT\Manifest_Invoker.rc"                      ; Application manifest definition

LANGUAGE LANG_NEUTRAL, SUBLANG_NEUTRAL


; Icons --------------------------------------------------------------------------------------------
ICON_APP  ICON DISCARDABLE "ICO\OA.ico"


; Bitmaps ------------------------------------------------------------------------------------------
BMP_BACKGROUND  BITMAP "BMP\WndBkgnd.bmp"


; Dialogs ------------------------------------------------------------------------------------------
#include "DLG\DialogAbout.rc"
#include "DLG\DialogPassword.rc"


; Gifs ---------------------------------------------------------------------------------------------

KEY GIF DISCARDABLE "GIF\Key.gif"


; Menus --------------------------------------------------------------------------------------------
MENU_APP MENUEX DISCARDABLE
BEGIN
  POPUP "&File", 0, MFT_STRING,   MFS_ENABLED
  BEGIN
    MENUITEM "&Exit", IDM_EXIT,   MFT_STRING, MFS_ENABLED
  END
  POPUP "&Help", 0, MFT_STRING,   MFS_ENABLED
  BEGIN
    MENUITEM "&Help",  IDM_HELP,  MFT_STRING, MFS_ENABLED
    MENUITEM "&About", IDM_ABOUT, MFT_STRING, MFS_ENABLED
  END
END
